generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  country              String
  locale               String    @default("en")
  features             String[]
  status               String    @default("PENDING_PAYMENT")
  taxId                String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  fiscalConfig         Json?     // { focusNfeToken, ambiente, razaoSocial, nomeFantasia, inscricaoEstadual, inscricaoMunicipal, codigoMunicipio, regimeTributario, itemListaServico, aliquotaISS, cnaeCode, logradouro, numero, complemento, bairro, municipio, uf, cep }
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users        User[]
  products     Product[]
  categories   Category[]
  invoices     Invoice[]
  serviceTypes ServiceType[]
  clients      Client[]

  @@unique([taxId])
  @@index([stripeCustomerId])
  @@index([status])
}

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId              String    @db.ObjectId
  email                 String
  name                  String
  passwordHash          String
  roles                 String[]
  refreshTokenHash      String?
  isActive              Boolean   @default(true)
  emailVerified         Boolean   @default(false)
  emailVerificationToken String?
  emailVerificationExpires DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relações de auditoria
  createdProducts     Product[]     @relation("ProductCreatedBy")
  updatedProducts     Product[]     @relation("ProductUpdatedBy")
  createdCategories   Category[]    @relation("CategoryCreatedBy")
  updatedCategories   Category[]    @relation("CategoryUpdatedBy")
  createdInvoices     Invoice[]     @relation("InvoiceCreatedBy")
  updatedInvoices     Invoice[]     @relation("InvoiceUpdatedBy")
  createdServiceTypes ServiceType[] @relation("ServiceTypeCreatedBy")
  updatedServiceTypes ServiceType[] @relation("ServiceTypeUpdatedBy")
  auditLogs         AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model Category {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId          String   @db.ObjectId
  name              String
  parentId          String?  @db.ObjectId
  attributeTemplate Json?
  createdById       String?  @db.ObjectId
  updatedById       String?  @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Category[]    @relation("CategoryToCategory")
  products     Product[]
  serviceTypes ServiceType[]
  createdBy    User?         @relation("CategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy    User?         @relation("CategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([tenantId])
  @@index([parentId])
  @@index([createdById])
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  categoryId  String?  @db.ObjectId
  name        String
  sku         String?
  priceCents  Int
  currency    String   @default("USD")
  attributes  Json     @default("{}")
  images      String[]
  // NF-e fiscal codes
  ncm                      String?
  cfop                     String?
  icmsSituacaoTributaria   String?
  icmsOrigem               Int?
  pisSituacaoTributaria    String?
  cofinsSituacaoTributaria String?
  isActive    Boolean  @default(true)
  createdById String?  @db.ObjectId
  updatedById String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User?     @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([isActive])
  @@index([createdById])
}

model Invoice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  country     String
  status      String   @default("DRAFT")
  payload     Json
  result      Json?
  createdById String?  @db.ObjectId
  updatedById String?  @db.ObjectId
  issuedById  String?  @db.ObjectId
  issuedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User?  @relation("InvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([tenantId])
  @@index([status])
  @@index([createdById])
  @@index([issuedAt])
}

// ===== COUPON =====
model Coupon {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  code            String   @unique
  discountPercent Int      // 1-100
  durationMonths  Int      // How many months the coupon applies
  maxUses         Int?     // null = unlimited
  currentUses     Int      @default(0)
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  createdById     String?  // Platform admin who created it
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

// ===== SERVICE TYPE =====
model ServiceType {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  name        String
  code        String   // Uppercase slug, e.g. "CREW_TRANSPORT"
  description String?

  // NFS-e fiscal codes (override tenant fiscalConfig when set)
  itemListaServico          String?  // LC116, e.g. "16.01"
  codigoTributacaoMunicipal String?
  aliquotaISS               Float?   // ISS rate %, e.g. 5.0
  cnaeCode                  String?

  // NF-e fiscal codes (for product invoice emission)
  ncm                      String?  // NCM 8 digits
  cfop                     String?  // e.g. "5102"
  icmsSituacaoTributaria   String?  // e.g. "102"
  icmsOrigem               Int?     // 0 = nacional
  pisSituacaoTributaria    String?  // e.g. "07"
  cofinsSituacaoTributaria String?  // e.g. "07"

  categoryId  String?  @db.ObjectId

  isActive    Boolean  @default(true)
  createdById String?  @db.ObjectId
  updatedById String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("ServiceTypeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User?     @relation("ServiceTypeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

// ===== SERVICE ORDER =====
model ServiceOrder {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId               String   @db.ObjectId
  orderNumber            String
  voucherNumber          String?
  status                 String   @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, INVOICED, CANCELED

  // Service details
  serviceType            String   // CREW_TRANSPORT, SUPPLY_TRANSPORT, etc
  serviceDescription     String
  servicePeriod          String   // DAY, NIGHT, DAY_NIGHT, WEEKEND_DAY, etc
  serviceDate            DateTime
  startTime              DateTime
  endTime                DateTime?

  // Vessel info
  vesselName             String
  vesselType             String   // NATIONAL, FOREIGN
  anchorageArea          String?

  // Company info
  companyName            String
  companyTaxId           String?

  // Boat/crew info
  boatName               String?
  captainName            String?
  employeeId             String?  @db.ObjectId
  employeeName           String?

  // People transported
  transportedPeople      Json?    // Array of { name, role, document }
  requestedBy            String?

  // Financial
  rateCents              Int
  currency               String   @default("BRL")
  additionalChargesCents Int      @default(0)
  discountCents          Int      @default(0)
  totalCents             Int

  notes                  String?
  items                  Json?    // Array of { productId, name, qty, unitCents, totalCents, notes? }

  // NFS-e data (stored after first issuance via Focus NFe)
  nfseData               Json?    // { numero, codigoVerificacao, pdfUrl, xmlBase64, issuedAt, ref, ambiente }

  createdById            String   @db.ObjectId
  updatedById            String   @db.ObjectId
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([tenantId])
  @@index([orderNumber])
  @@index([status])
  @@index([companyName])
  @@index([vesselName])
  @@index([serviceDate])
  @@index([createdAt])
}

// ===== AUDIT LOG =====
model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String   @db.ObjectId
  userId     String   @db.ObjectId
  action     String   // CREATE, UPDATE, DELETE, ISSUE, CANCEL, LOGIN, LOGOUT
  entity     String   // Product, Category, Invoice, User
  entityId   String?  // ID do registro afetado
  entityName String?  // Nome/descrição para fácil identificação
  oldData    Json?    // Dados antes da alteração
  newData    Json?    // Dados após a alteração
  metadata   Json?    // Informações adicionais (IP, user-agent, etc)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

// ===== SUPPORT TICKET =====
model SupportTicket {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  userId      String   @db.ObjectId
  category    String   // FEATURE_REQUEST, BUG_REPORT, COMPLAINT, QUESTION, OTHER
  subject     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    SupportMessage[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model SupportMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId  String   @db.ObjectId
  senderId  String   // userId or "admin"
  senderName String
  isAdmin   Boolean  @default(false)
  content   String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

// ===== AFFILIATE SYSTEM =====
model Affiliate {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  email         String   @unique
  cpf           String?  @unique
  name          String?
  type          String   @default("STANDARD") // STANDARD (10%) or PARTNER (40%)
  status        String   @default("PENDING") // PENDING (invited, not yet registered) or ACTIVE
  userId        String?  @db.ObjectId // Linked user after they sign up, null if not registered yet
  inviteToken   String?
  payoutInfo    Json?    // { method: 'pix'|'bank'|'stripe', pixKeyType?, pixKey?, bankName?, bankAgency?, bankAccount?, bankAccountType?, stripeConnectAccountId? }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantLinks   TenantAffiliate[]
  commissions   AffiliateCommission[]

  @@index([userId])
  @@index([inviteToken])
}

model TenantAffiliate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  affiliateId String   @db.ObjectId
  linkedAt    DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@unique([tenantId, affiliateId])
  @@index([tenantId])
  @@index([affiliateId])
}

model AffiliateCommission {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  affiliateId     String   @db.ObjectId
  tenantId        String   @db.ObjectId
  paymentAmountCents Int   // Total payment amount from the tenant
  commissionPercent  Float // Actual % this affiliate gets (e.g. 10, 5, 40, 20)
  commissionCents    Int   // Calculated commission amount
  stripeInvoiceId String?  // Reference to the Stripe invoice
  status          String   @default("PENDING") // PENDING, PAID
  periodStart     DateTime?
  periodEnd       DateTime?
  createdAt       DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

// ===== CLIENT (CNPJ/CPF BOOK) =====
model Client {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  name        String   // Razão Social
  tradeName   String?  // Nome Fantasia
  taxId       String?  // CNPJ or CPF
  email       String?
  phone       String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  municipio   String?
  uf          String?
  cep         String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, taxId])
  @@index([tenantId])
  @@index([isActive])
}
